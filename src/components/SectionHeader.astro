---
import { createTranslate } from "../lib/i18n";
import type { Translation, Language } from "../types";
import { marked } from "marked";

interface Props {
  title: Translation;
  subtitle?: Translation;
  lang: Language;
  theme?: 'dark' | 'light';
  class?: string;
}

const { title, subtitle, lang, theme = 'dark', class: className } = Astro.props;
const t = createTranslate(lang);

const styles = {
  dark: {
    title: 'text-white',
    subtitle: 'text-white/70',
  },
  light: {
    title: 'text-gray-900',
    subtitle: 'text-gray-600',
  }
};

const style = styles[theme];

function decodeHtml(html: string) {
  return html
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&amp;/g, "&");
}
---

<div class:list={["text-center mb-12 max-w-2xl mx-auto", className]}>
  <h2 class:list={["text-2xl md:text-4xl font-bold mb-4", style.title]}>
    {t(title)}
  </h2>
  {subtitle && (
    <div 
      class:list={["text-md md:text-lg content-rich-text", style.subtitle]}
      set:html={marked.parse(decodeHtml(t(subtitle)))}
    />
  )}
</div>


