---
import * as LucideIcons from "lucide-react";
import type { Translation, Language } from "../../types";
import SectionHeader from "../SectionHeader.astro";
import { createTranslate } from "../../lib/i18n";

interface BrandValue {
  id: number;
  icon: string;
  title: Translation;
  description: Translation;
}

interface Props {
  title?: Translation;
  subtitle?: Translation;
  items?: BrandValue[];
  lang: Language;
}

const { title, subtitle, items = [], lang } = Astro.props;
const t = createTranslate(lang);
---

{
  items.length > 0 && (
    <section class="py-12 w-full">
      <div class="container mx-auto px-4">
        {title && (
          <SectionHeader
            lang={lang}
            title={title}
            subtitle={subtitle}
            theme="light"
          />
        )}

        <div class="grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] md:grid-cols-[repeat(auto-fit,minmax(240px,1fr))]  justify-between max-w-6xl mx-auto gap-2 md:gap-4">
          {items.map((item) => {
            const Icon = (LucideIcons as any)[item.icon] || LucideIcons.Star;
            return (
              <div class="text-center group">
                <div class="w-12 h-12 mx-auto bg-primary/10 rounded-full flex items-center justify-center mb-3 group-hover:bg-primary/20 transition-colors">
                  <Icon class="w-6 h-6 text-primary" />
                </div>
                <h4 class="font-medium mb-1">{t(item.title)}</h4>
                <p class="text-sm text-gray-500 max-w-xs line-clamp-2">
                  {t(item.description)}
                </p>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )
}
