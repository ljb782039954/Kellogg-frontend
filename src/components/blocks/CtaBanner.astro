---
import type { Translation, NavLink, Language } from "../../types";
import { createTranslate } from "../../lib/i18n";
import OptimizedImage from "../ui/OptimizedImage.astro";
import SectionHeader from "../SectionHeader.astro";

interface CtaBannerValues {
  primaryButton?: NavLink;
  secondaryButton?: NavLink;
  backgroundImage?: string;
  backgroundColor?: string;
  alignment?: "left" | "center" | "right";
}

interface Props {
  title?: Translation;
  subtitle?: Translation;
  values?: CtaBannerValues;
  lang: Language;
}

const { title, subtitle, values, lang } = Astro.props;
const t = createTranslate(lang);

const alignClass = {
  left: "text-left items-start",
  center: "text-center items-center",
  right: "text-right items-end",
}[values?.alignment || "center"];
---

<div class="relative rounded-2xl overflow-hidden text-white my-8 mx-4">
  {
    values?.backgroundImage ? (
      <>
        <OptimizedImage
          src={values.backgroundImage}
          alt=""
          class="absolute inset-0 w-full h-full object-cover"
          sizes="100vw"
        />
        <div class="absolute inset-0 bg-black/50" />
      </>
    ) : (
      <div
        class="absolute inset-0 bg-gradient-to-br from-primary to-purple-700"
        style={
          values?.backgroundColor
            ? { backgroundColor: values.backgroundColor }
            : undefined
        }
      />
    )
  }
  <div
    class:list={[
      "relative container mx-auto px-6 py-16 flex flex-col",
      alignClass,
    ]}
  >
    {
      title && (
        <SectionHeader
          lang={lang}
          title={title}
          subtitle={subtitle}
          theme="dark"
        />
      )
    }
    <div class="flex flex-wrap gap-4 mt-6">
      {
        values?.primaryButton?.name && (
          <a
            href={values.primaryButton.href}
            class="px-8 py-3 bg-white text-gray-900 rounded-lg font-bold hover:bg-gray-100 transition-colors shadow-lg"
          >
            {t(values.primaryButton.name)}
          </a>
        )
      }
      {
        values?.secondaryButton?.name && (
          <a
            href={values.secondaryButton.href}
            class="px-8 py-3 bg-white/20 backdrop-blur-sm text-white border border-white/30 rounded-lg font-bold hover:bg-white/30 transition-colors"
          >
            {t(values.secondaryButton.name)}
          </a>
        )
      }
    </div>
  </div>
</div>
