---
import * as LucideIcons from 'lucide-react';
import type { Translation, Language } from "../../types";
import SectionHeader from "../SectionHeader.astro";
import { createTranslate } from "../../lib/i18n";
import { marked } from "marked";

interface FeatureListItem {
  icon: string;
  title: Translation;
  description: Translation;
}

interface Props {
  title?: Translation;
  subtitle?: Translation;
  items?: FeatureListItem[];
  lang: Language;
}

const { title, subtitle, items = [], lang } = Astro.props;
const t = createTranslate(lang);
---

{items.length > 0 && (
  <section class="py-12 w-full">
    <div class="container mx-auto px-4">
      {title && <SectionHeader lang={lang} title={title} subtitle={subtitle} theme="light" />}
      
      <div class="grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] md:grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-4 md:gap-6">
        {items.map((item) => {
          const Icon = (LucideIcons as any)[item.icon] || LucideIcons.Star;
          return (
            <div class="bg-gray-50 rounded-xl p-6 hover:bg-primary/5 hover:shadow-md transition-all group">
              <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
                <Icon class="w-6 h-6 text-primary" />
              </div>
              <h4 class="font-semibold mb-2">{t(item.title)}</h4>
              <div class="text-sm text-gray-500 content-rich-text" set:html={marked.parse(t(item.description))} />
            </div>
          );
        })}
      </div>
    </div>
  </section>
)}

