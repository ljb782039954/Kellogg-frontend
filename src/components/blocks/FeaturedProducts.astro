---
import type { Translation, Product, Language } from "../../types";

interface Props {
  title?: Translation;
  subtitle?: Translation;
  maxItems?: number;
  products: Product[];
  lang: Language;
}

import FeaturedProductsReact from "./FeaturedProducts.tsx";

const { title, subtitle, maxItems, products = [], lang } = Astro.props;
---

<FeaturedProductsReact
  client:load
  title={title}
  subtitle={subtitle}
  maxItems={maxItems}
  initialProducts={products}
  lang={lang}
/>
)}
