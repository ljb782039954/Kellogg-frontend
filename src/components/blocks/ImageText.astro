---
import type { Translation, Language } from "../../types";
import OptimizedImage from "../ui/OptimizedImage.astro";
import { createTranslate } from "../../lib/i18n";
import { marked } from "marked";

interface Props {
  title?: Translation;
  content?: Translation;
  image?: string;
  imagePosition?: "left" | "right";
  buttonText?: Translation;
  buttonLink?: string;
  lang: Language;
}

const {
  title,
  content,
  image,
  imagePosition = "left",
  buttonText,
  buttonLink,
  lang,
} = Astro.props;

const t = createTranslate(lang);

// const value = content ? t(content) : "";

const isInternal = buttonLink?.startsWith("/");

// HTML 实体反转义，确保富文本标签在渲染时生效
function decodeHtml(html: string) {
  return html
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&amp;/g, "&");
}
---

<section class="py-12">
  <div class="container mx-auto px-4">
    <div
      class:list={[
        "grid grid-cols-1 md:grid-cols-[repeat(auto-fit,minmax(360px,1fr))] items-center gap-8 md:gap-12 px-4",
        imagePosition === "right" ? "md:flex-row-reverse" : "",
      ]}
    >
      {/* 图片 */}
      <div class="flex-1 w-full">
        <div class="aspect-[4/3] rounded-lg overflow-hidden">
          <OptimizedImage
            src={image}
            alt={title ? t(title) : "Section Image"}
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      {/* 文本 */}
      <div class="flex-1 space-y-4">
        {title && <h3 class="text-2xl md:text-4xl font-bold">{t(title)}</h3>}

        <div class="text-gray-600 text-md md:text-lg leading-relaxed content-rich-text" set:html={marked.parse(decodeHtml(t(content)))} />

        {
          buttonText && buttonLink && (
            <a
              href={buttonLink}
              target={isInternal ? undefined : "_blank"}
              rel={isInternal ? undefined : "noopener noreferrer"}
            >
              <button class="px-6 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors">
                {t(buttonText)}
              </button>
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>

