---
import type { Translation, Language } from "../../types";
import { createTranslate } from "../../lib/i18n";
import { marked } from "marked";

interface Props {
  title?: Translation;
  content?: Translation;
  alignment?: "left" | "center" | "right";
  paddingY?: "small" | "medium" | "large";
  backgroundColor?: string;
  lang: Language;
}

const {
  title,
  content,
  alignment = "center",
  backgroundColor,
  lang,
} = Astro.props;
const t = createTranslate(lang);

// HTML 实体反转义，确保富文本标签在渲染时生效
function decodeHtml(html: string) {
  return html
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&amp;/g, "&");
}
---

<section
  class:list={[
    "py-12",
    backgroundColor ? `bg-[${backgroundColor}]` : "bg-gray-50",
    alignment === "center"
      ? "text-center"
      : alignment === "right"
        ? "text-right"
        : "text-left",
  ]}
>
  <div class="container mx-auto px-4">
    {
      title && (
        <h1 class="text-2xl md:text-4xl font-bold text-gray-800 mb-4">
          {t(title)}
        </h1>
      )
    }
    {
      content && (
        <div class="text-sm text-gray-500 content-rich-text" set:html={marked.parse(decodeHtml(t(content)))} />
      )
    }
  </div>
</section>

