---
import type { Translation, Language } from "../../types";
import { createTranslate } from "../../lib/i18n";
import ProductVideo from "../ProductVideo.astro";

interface VideoSectionValues {
  videoUrl?: string;
  posterImage?: string;
  autoPlay?: boolean;
  loop?: boolean;
}

interface Props {
  title?: Translation;
  subtitle?: Translation;
  videoUrl?: string;
  values?: VideoSectionValues;
  lang: Language;
}

const { title, subtitle, videoUrl, values, lang } = Astro.props;
const t = createTranslate(lang);

const finalVideoUrl = videoUrl || values?.videoUrl;
---

{finalVideoUrl && (
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto space-y-10">
        {(title || subtitle) && (
          <div class="text-center space-y-4 max-w-2xl mx-auto">
            {title && (
              <h2 class="text-4xl font-bold text-gray-900 tracking-tight">
                {t(title)}
              </h2>
            )}
            {subtitle && (
              <p class="text-lg text-gray-500 font-light leading-relaxed">
                {t(subtitle)}
              </p>
            )}
            <div class="w-12 h-1 bg-gray-900 mx-auto rounded-full mt-6" />
          </div>
        )}
        
        <div class="shadow-2xl rounded-[40px] overflow-hidden">
          <ProductVideo url={finalVideoUrl} />
        </div>
      </div>
    </div>
  </section>
)}
