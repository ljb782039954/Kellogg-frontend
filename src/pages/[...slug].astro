---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import { api } from "../lib/api";
import { SiteService } from "../services/siteService";
import DynamicRenderer from "../components/DynamicRenderer.astro";
import InquirySection from "../components/blocks/InquirySection";

export async function getStaticPaths() {
  // 在构建时获取所有站点数据
  const { pages } = await SiteService.getSiteData(); 
  
  return pages.map(page => {
    // 处理路径，去掉前缀斜杠并处理空路径（首页）
    const slug = page.path === '/' ? undefined : page.path.replace(/^\//, '');
    return {
      params: { slug },
      props: { pageId: page.id } // 传给页面，避免重复查找
    };
  });
}

const { slug } = Astro.params;
const { pageId } = Astro.props;
const path = slug === undefined ? "/" : `/${slug}`;

// 1. 获取站点全局数据
const siteData = await SiteService.getSiteData(Astro);
const { lang } = siteData;

// 2. 获取页面的详细数据 (包含积木块)
const fullPage = await api.getPageById(pageId);

if (!fullPage) {
  console.error(`[Astro] Page not found for ID: ${pageId}`);
  return Astro.redirect("/");
}
---

<Layout title={fullPage.title} lang={lang} seo={fullPage.seo}>
  {
    pageId === "system-inquiry" ? (
      <div class="py-12">
        <InquirySection lang={lang} client:load />
      </div>
    ) : (
      <DynamicRenderer schema={fullPage} lang={lang} />
    )
  }
</Layout>
